# Database (Supabase PostgreSQL - Session mode port 5432)
DATABASE_URI=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require

# Payload CMS
PAYLOAD_SECRET=your-payload-secret-min-32-chars-long

# Google Maps Distance Matrix API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Resend (Transactional Email)
RESEND_API_KEY=re_your-resend-api-key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
